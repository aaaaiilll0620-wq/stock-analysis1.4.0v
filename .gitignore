# 忽略環境變數文件 (含 FinMind token — 絕不上傳)
.env
*.env
# 忽略 Python 快取
__pycache__/
*.pyc
.pytest_cache/

# ---- 部署精簡:以下不要推上 GitHub (體積大 / 本機專用 / 會重生成) ----
# PyInstaller 打包產物
dist/
build/
*.spec
# 執行輸出 (回測報表、驗證 CSV 等)
outputs/
# 本機原始資料快取 (幾百 MB;雲端不需要,靠 cloud_cache 快照)
finmind_cache/
data/
backups/
# 編輯器 / 系統
.vscode/
.DS_Store

# ---- 例外:cloud_cache 是要『刻意提交』的 scores 快照,別忽略它 ----
!cloud_cache/
!cloud_cache/**
